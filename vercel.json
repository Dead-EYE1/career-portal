{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mocktest.newjobupdates.in" }],
      "destination": "/mocktest.html"
    },
    {
      "source": "/mock-test",
      "destination": "/mocktest.html"
    },
    {
      "source": "/mock-test.html",
      "destination": "/mocktest.html"
    }
  ]
}
