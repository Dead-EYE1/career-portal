{
  "redirects": [
    {
      "source": "/mock-test.html",
      "destination": "/mocktest.html",
      "statusCode": 301
    },
    {
      "source": "/mock-test",
      "destination": "/mocktest.html",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/post/(.*)",
      "destination": "/job.html?id=$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mocktest.newjobupdates.in" }],
      "destination": "/mocktest.html"
    }
  ]
}