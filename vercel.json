{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mocktest.newjobupdates.in" }],
      "destination": "/mocktest.html"
    },
    {
      "source": "/mock-test",
      "destination": "/mocktest.html"
    },
    {
      "source": "/mock-test.html",
      "destination": "/mocktest.html"
    },
    {
      "source": "/mocktest",
      "destination": "/mocktest.html"
    },
    {
      "source": "/mocktest.html",
      "destination": "/mocktest.html"
    },
    {
      "source": "/((?!style\\.css|script\\.js|favicon\\.svg|.*\\.png|.*\\.jpg|.*\\.jpeg|mocktest\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
