{
  "redirects": [
    {
      "source": "/mock-test.html",
      "destination": "/mocktest.html",
      "statusCode": 301
    },
    {
      "source": "/mock-test",
      "destination": "/mocktest.html",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:path*",
